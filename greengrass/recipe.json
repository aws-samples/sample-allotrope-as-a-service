{
  "RecipeFormatVersion": "2020-01-25",
  "ComponentName": "com.aws.asm.EdgeClient",
  "ComponentVersion": "1.0.0",
  "ComponentDescription": "ASM Transformation Edge Client for laboratory instruments",
  "ComponentPublisher": "AWS",
  "ComponentConfiguration": {
    "DefaultConfiguration": {
      "apiGatewayUrl": "https://2utxx41y1l.execute-api.us-east-1.amazonaws.com/prod",
      "watchDirectory": "/opt/instruments/output",
      "logLevel": "INFO",
      "auditEnabled": true
    }
  },
  "Manifests": [
    {
      "Platform": {
        "os": "linux"
      },
      "Lifecycle": {
        "Install": "pip3 install -r requirements.txt",
        "Run": "python3 asm_edge_client.py"
      },
      "Artifacts": [
        {
          "URI": "s3://asm-greengrass-artifacts/asm_edge_client.py"
        },
        {
          "URI": "s3://asm-greengrass-artifacts/requirements.txt"
        }
      ]
    }
  ]
}